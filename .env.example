# ══════════════════════════════════════════════════════════════════
# .env.example — Enterprise CX Guardian AI
# Copy this file to .env and fill in all required values.
#
# Usage:
#   cp .env.example .env
#   docker compose up --build
# ══════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── MongoDB ───────────────────────────────────────────────────────
# Root credentials for the MongoDB Docker container
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Database name (shared across all services)
DATABASE_NAME=cx_guardian_db

# Port exposed on the host (default: 27017)
MONGO_PORT=27017

# ── Groq AI (REQUIRED) ────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_API_KEY

# AI Model settings
MODEL_NAME=llama3-70b-8192
TEMPERATURE=0.2
MAX_TOKENS=1024
MAX_HISTORY=10
MAX_CONVERSATIONS=100
AUTO_DELETE_EMPTY=True

# ── JWT Auth (REQUIRED — must be the same in ALL services) ─────────
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_SECRET_DO_NOT_USE_THIS_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Node Backend ──────────────────────────────────────────────────
AI_TIMEOUT=30000
MAX_RETRIES=3

# ── CORS / URLs ───────────────────────────────────────────────────
# URL of the frontend (used by Node backend CORS policy)
CLIENT_URL=http://localhost:80

# Vite environment variables (baked into frontend JS bundle at build time)
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# ── Host Port Overrides (optional) ────────────────────────────────
# Change only if you have port conflicts on your machine
CLIENT_PORT=80
SERVER_PORT=5000
AI_SERVICE_PORT=8000
